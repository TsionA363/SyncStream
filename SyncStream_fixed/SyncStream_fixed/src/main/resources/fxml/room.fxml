<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.syncstream.gui.RoomController"
            style="-fx-background-color: #0a0a0a;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #16213e; -fx-padding: 10 20;">
            <Label fx:id="roomInfoLabel" style="-fx-text-fill: #e94560; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="participantCountLabel" style="-fx-text-fill: #cccccc;"/>
            <Button text="⬅ Leave Room" onAction="#onLeaveRoom"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <HBox>

            <VBox fx:id="videoContainer" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: black;">

                <MediaView fx:id="mediaView" VBox.vgrow="ALWAYS" preserveRatio="true"/>

                <HBox fx:id="timelineRow" alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #111122; -fx-padding: 8 12;">
                    <Label fx:id="timeLabel" text="0:00 / 0:00"
                           style="-fx-text-fill: #cccccc; -fx-min-width: 110;"/>
                    <Slider fx:id="seekSlider" HBox.hgrow="ALWAYS" min="0" max="100"
                            onMousePressed="#onSeekStart" onMouseReleased="#onSeekEnd"
                            style="-fx-accent: #e94560;"/>
                </HBox>

                <HBox fx:id="hostControls" alignment="CENTER" spacing="16"
                      style="-fx-background-color: #16213e; -fx-padding: 10;">
                    <Button text="▶ Play" onAction="#onPlay"
                            style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
                            prefWidth="110"/>
                    <Button text="⏸ Pause" onAction="#onPause"
                            style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
                            prefWidth="110"/>
                    <Label text="Host Controls — you are broadcasting sync to all viewers"
                           style="-fx-text-fill: #888888; -fx-font-size: 11;"/>
                </HBox>

                <HBox alignment="CENTER" spacing="12"
                      style="-fx-background-color: #0f0f1a; -fx-padding: 8;">
                    <Label text="React:" style="-fx-text-fill: #888888;"/>
                    <Button text="👍" onAction="#onReact1" style="-fx-font-size: 18; -fx-background-color: transparent; -fx-cursor: hand;"/>
                    <Button text="❤️" onAction="#onReact2" style="-fx-font-size: 18; -fx-background-color: transparent; -fx-cursor: hand;"/>
                    <Button text="😂" onAction="#onReact3" style="-fx-font-size: 18; -fx-background-color: transparent; -fx-cursor: hand;"/>
                    <Button text="😮" onAction="#onReact4" style="-fx-font-size: 18; -fx-background-color: transparent; -fx-cursor: hand;"/>
                    <Button text="😢" onAction="#onReact5" style="-fx-font-size: 18; -fx-background-color: transparent; -fx-cursor: hand;"/>
                </HBox>

            </VBox>

            <VBox prefWidth="300" style="-fx-background-color: #16213e;">
                <Label text="💬 Live Chat"
                       style="-fx-text-fill: #e94560; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10 12 5 12;"/>
                <Separator style="-fx-background-color: #333355;"/>

                <ListView fx:id="chatList" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #0f0f1a; -fx-text-fill: #dddddd; -fx-border-color: transparent;"/>

                <HBox spacing="6" style="-fx-padding: 8 8 8 8;">
                    <TextField fx:id="chatInput" promptText="Type a message..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #0f3460; -fx-text-fill: white;"
                               onAction="#onSendChat"/>
                    <Button text="Send" onAction="#onSendChat"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-cursor: hand;"/>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>